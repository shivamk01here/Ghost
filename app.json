{
  "expo": {
    "name": "Aegis",
    "slug": "ghost-journal",
    "scheme": ["ghostjournal", "com.shivam01here.ghostjournal"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/aegis.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/aegis.png",
      "resizeMode": "contain",
      "backgroundColor": "#120A22"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#120A22",
        "foregroundImage": "./assets/aegis.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.shivam01here.ghostjournal"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-sharing",
      "expo-audio",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Ghost Journal to save photos to your library.",
          "savePhotosPermission": "Allow Ghost Journal to save your encrypted photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "extraParams": [
              "-Dkotlin.incremental=false"
            ]
          }
        }
      ],
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "6a58064f-88ec-4b81-b011-090dd22c8efc"
      }
    }
  }
}
